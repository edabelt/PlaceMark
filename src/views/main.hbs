{{> welcome-menu}}

<section class="hero is-light is-medium">
  <div class="hero-body">
    <div class="container">

      <div class="columns is-vcentered is-variable is-6">

        <div class="column is-half">
          <h1 class="title is-2">
            Welcome to PlaceMark
          </h1>

          <p class="subtitle is-5">
            Discover, organise, and manage your favourite places.
          </p>

          <p class="mb-5">
            Sign up or log in to start building your own collection of placemarks and organise them by category.
          </p>

          <div class="buttons">
            <a href="/signup" class="button is-primary is-medium">
              Sign Up
            </a>

            <a href="/login" class="button is-link is-light is-medium">
              Log In
            </a>
          </div>
        </div>

        <div class="column is-half">
          <figure class="image is-4by3">
            <img src="/images/cloud-img.jpg" alt="PlaceMark welcome image">
          </figure>
        </div>

      </div>

    </div>
  </div>
</section>