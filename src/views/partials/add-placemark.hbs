<form class="box" action="/category/{{playlist._id}}/addplacemark" method="POST">
  <h2 class="title is-5">Add New PlaceMark</h2>

  <div class="field">
    <label class="label">Name</label>
    <div class="control">
      <input class="input" type="text" placeholder="Enter place name" name="name">
    </div>
  </div>

  <div class="field">
    <label class="label">Location Name</label>
    <div class="control has-addons">
      <input id="locationName" class="input" type="text" placeholder="Enter city or place" name="locationName">
      <button type="button" class="button is-info" onclick="findCoordinates()">Find</button>
    </div>
  </div>

  <div class="field">
    <label class="label">Latitude</label>
    <div class="control">
      <input id="latitude" class="input" type="text" placeholder="Latitude will autofill" name="latitude">
    </div>
  </div>

  <div class="field">
    <label class="label">Longitude</label>
    <div class="control">
      <input id="longitude" class="input" type="text" placeholder="Longitude will autofill" name="longitude">
    </div>
  </div>

  <div class="field">
    <label class="label">Description</label>
    <div class="control">
      <textarea class="textarea" name="description" placeholder="Describe this place (max 500 words)"></textarea>
    </div>
  </div>

  <div class="field">
    <label class="label">Image URL</label>
    <div class="control">
      <input class="input" type="text" placeholder="Enter image URL" name="image">
    </div>
  </div>

  <div class="field">
    <div class="control">
      <button class="button is-primary is-fullwidth">
        Add PlaceMark
      </button>
    </div>
  </div>
</form>

<script>
  async function findCoordinates() {
    const location = document.getElementById("locationName").value.trim();

    if (!location) {
      alert("Please enter a location name first");
      return;
    }

    const response = await fetch(
      `https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(location)}`
    );

    const data = await response.json();

    if (data.length === 0) {
      alert("Location not found");
      return;
    }

    const lat = parseFloat(data[0].lat);
    const lon = parseFloat(data[0].lon);

    document.getElementById("latitude").value = lat;
    document.getElementById("longitude").value = lon;

    if (window.map) {
      window.map.setView([lat, lon], 13);

      if (window.previewMarker) {
        window.map.removeLayer(window.previewMarker);
      }

      window.previewMarker = L.marker([lat, lon])
        .addTo(window.map)
        .bindPopup("New PlaceMark Preview")
        .openPopup();
    }
  }
</script>