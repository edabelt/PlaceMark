<table class="table is-fullwidth is-striped is-hoverable">
  <thead>
  <tr>
    <th>Name</th>
    <th>Latitude</th>
    <th>Longitude</th>
    <th class="has-text-centered">Edit</th>
    <th class="has-text-centered">Delete</th>
  </tr>
</thead>

  <tbody>
    {{#each playlist.tracks}}
      <tr>
        <td>{{name}}</td>
        <td>{{latitude}}</td>
        <td>{{longitude}}</td>

        <td class="has-text-centered">
          <a href="/placemark/{{../playlist._id}}/edit/{{_id}}" class="button is-small is-link is-light">
            <span class="icon">
              <i class="fas fa-edit"></i>
            </span>
          </a>
        </td>

        <td class="has-text-centered">
          <a href="/category/{{../playlist._id}}/deleteplacemark/{{_id}}" class="button is-small is-danger is-light">
            <span class="icon">
              <i class="fas fa-trash"></i>
            </span>
          </a>
        </td>

      </tr>
    {{/each}}
  </tbody>
</table>