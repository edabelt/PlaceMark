{{#each playlists}}
  <div class="box">
    <div class="level">

      <div class="level-left">
        <div class="level-item">
          <h2 class="title is-5">{{title}}</h2>
        </div>
      </div>

      <div class="level-right">

        <div class="level-item">
          <a href="/category/{{_id}}" class="button is-link is-light">
            <span class="icon">
              <i class="fas fa-folder-open"></i>
            </span>
            <span>Open</span>
          </a>
        </div>

        <div class="level-item">
          <a href="/dashboard/deletecategory/{{_id}}" class="button is-danger is-light">
            <span class="icon">
              <i class="fas fa-trash"></i>
            </span>
            <span>Delete</span>
          </a>
        </div>

      </div>

    </div>
  </div>
{{/each}}