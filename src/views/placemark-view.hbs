{{> menu}}

<section class="section">
  <div class="container">
    <div class="columns is-centered">
      <div class="column is-half">

        <div class="box">
          <h1 class="title is-4">Edit PlaceMark</h1>

          {{> error}}

          <form action="/placemark/{{playlist._id}}/update/{{track._id}}" method="POST">

            <div class="field">
              <label class="label">Name</label>
              <div class="control">
                <input class="input" type="text" name="name" value="{{track.name}}">
              </div>
            </div>

            <div class="field">
              <label class="label">Location</label>
              <div class="control">
                <input class="input" type="text" name="locationName" value="{{track.locationName}}">
              </div>
            </div>

            <div class="field">
              <label class="label">Latitude</label>
              <div class="control">
                <input class="input" type="text" name="latitude" value="{{track.latitude}}">
              </div>
            </div>

            <div class="field">
              <label class="label">Longitude</label>
              <div class="control">
                <input class="input" type="text" name="longitude" value="{{track.longitude}}">
              </div>
            </div>

            <div class="field">
              <label class="label">Description</label>
              <div class="control">
                <textarea class="textarea" name="description" placeholder="Write a short description of the place (max 500 characters)">{{track.description}}</textarea>
              </div>
            </div>

            <div class="field">
              <label class="label">Image URL (temporary)</label>
              <div class="control">
                <input class="input" type="text" name="image" value="{{track.image}}">
              </div>
            </div>

            {{#if track.image}}
              <div class="field">
                <label class="label">Current Image</label>
                <figure class="image is-4by3">
                  <img src="{{track.image}}" alt="{{track.name}}">
                </figure>
              </div>
            {{/if}}

            <div class="field">
              <button class="button is-primary is-fullwidth">
                Update PlaceMark
              </button>
            </div>

          </form>
        </div>

      </div>
    </div>
  </div>
</section>