{{> menu}}

<section class="section">
  <div class="container">
    <div class="columns is-centered">
      <div class="column is-half">

        <div class="box">
          <h1 class="title is-4">Edit PlaceMark</h1>

          {{> error}}

          <form action="/placemark/{{playlist._id}}/update/{{track._id}}" method="POST">

            <div class="field">
              <label class="label">Name</label>
              <div class="control">
                <input class="input" type="text" name="name" value="{{track.name}}">
              </div>
            </div>

            <div class="field">
              <label class="label">Latitude</label>
              <div class="control">
                <input class="input" type="text" name="latitude" value="{{track.latitude}}">
              </div>
            </div>

            <div class="field">
              <label class="label">Longitude</label>
              <div class="control">
                <input class="input" type="text" name="longitude" value="{{track.longitude}}">
              </div>
            </div>

            <div class="field">
              <button class="button is-primary is-fullwidth">
                Update PlaceMark
              </button>
            </div>

          </form>
        </div>

      </div>
    </div>
  </div>
</section>