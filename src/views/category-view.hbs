{{> menu}}

<section class="section">
  <div class="container">
    <div class="mb-5">
      <h1 class="title is-3">{{playlist.title}}</h1>
      <p class="subtitle is-6">Manage the placemarks in this category.</p>
    </div>

    {{> error}}

    <div class="columns is-variable is-6">
      <div class="column is-three-quarters">
        <div class="box">
          <div class="level">
            <div class="level-left">
              <h2 class="title is-5 mb-0">PlaceMarks</h2>
            </div>
          </div>

          {{> list-placemarks}}
        </div>
      </div>

      <div class="column is-one-quarter">
        <div class="box">
          <h2 class="title is-5">Add New PlaceMark</h2>
          {{> add-placemark}}
        </div>
      </div>
    </div>
  </div>
</section>