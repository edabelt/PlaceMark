{{> menu}}

<section class="section">
  <div class="container">
    <div class="mb-5">
      <h1 class="title is-3">{{playlist.title}}</h1>
      <p class="subtitle is-6">Manage the placemarks in this category.</p>
    </div>

    {{> error}}

    <div class="columns is-variable is-6">
      <div class="column is-two-thirds">
        <div class="box">
          <h2 class="title is-5">PlaceMarks</h2>
          {{> list-placemarks}}
        </div>
      </div>

      <div class="column">
        <div class="box">
          <h2 class="title is-5">Add New PlaceMark</h2>
          {{> add-placemark}}
        </div>
      </div>
    </div>
  </div>
</section>