<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{title}}</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@0.9.3/css/bulma.min.css">
    <link rel="icon" href="https://cdn-icons-png.flaticon.com/512/252/252025.png">
    <script src="https://use.fontawesome.com/releases/v5.15.4/js/all.js"></script>

    <style>
      html, body {
        height: 100%;
      }

      body {
        display: flex;
        flex-direction: column;
        background-color: #f7f9fb;
      }

      main {
        flex: 1;
      }

      .placemark-card {
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 8px 20px rgba(10, 10, 10, 0.08);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
      }

      .placemark-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 14px 28px rgba(10, 10, 10, 0.12);
      }

      .navbar.is-primary,
      .footer.has-background-primary {
        background-color: #48c78e !important;
      }

      #map {
        border-radius: 12px;
      }

      .box {
        border-radius: 12px;
        box-shadow: 0 8px 20px rgba(10, 10, 10, 0.06);
      }
    </style>
  </head>

  <body>
    <main>
      {{{content}}}
      {{> error}}
    </main>

    {{> footer}}
  </body>
</html>